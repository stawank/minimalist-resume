{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open index.html in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "file": "${workspaceFolder}/frontend/index.html"
    },
    {
      "name": "Attach to Chrome",
      "port": 9222,
      "request": "attach",
      "type": "pwa-chrome",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Open index.html in Firefox",
      "type": "firefox",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    },
    {
      "name": "Attach index.html in Firefox",
      "type": "firefox",
      "request": "attach",
      "file": "${workspaceFolder}/index.html"
    }
  ]
}